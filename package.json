    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "fast-check": "^3.14.0",
    "vite": "^5.0.7",
    "vitest": "^1.1.0"
  }
}
